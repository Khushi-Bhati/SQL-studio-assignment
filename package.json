{
  "name": "ciphersqlstudio",
  "version": "1.0.0",
  "description": "A browser-based SQL learning platform",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "install-all": "npm install && cd client && npm install",
    "seed": "node database/seed.js"
  },
  "keywords": [
    "sql",
    "learning",
    "education"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mongodb": "^6.3.0",
    "pg": "^8.11.3",
    "openai": "^4.20.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}