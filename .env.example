# Server Configuration
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# PostgreSQL Configuration (Sandbox Database)
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=ciphersqlstudio

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/ciphersqlstudio
MONGODB_DB_NAME=ciphersqlstudio

# OpenAI Configuration (for LLM hints)
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Alternative: Use OPENAI_KEY if you prefer
# OPENAI_KEY=your_openai_api_key_here
